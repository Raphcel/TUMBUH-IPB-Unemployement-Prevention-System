# Local Docker PostgreSQL through docker-compose.yml
# Host port is 5433 because docker-compose maps 5433 -> 5432.
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/career_tracker

# Supabase Session Pooler example for shared dev/staging or IPv4-only hosts.
# Append ?sslmode=require unless the dashboard-provided URL already includes SSL behavior.
# DATABASE_URL=postgresql://postgres.xvtwlzwjzjhqfgutkavw:YOUR_PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres?sslmode=require

# Supabase direct connection example for persistent backend hosts with IPv6 support.
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.xvtwlzwjzjhqfgutkavw.supabase.co:5432/postgres?sslmode=require

DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
SECRET_KEY=change-this-to-a-strong-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Optional deployment settings
# Comma-separated or JSON array, e.g. https://app.example.com,https://admin.example.com
CORS_ORIGINS=http://127.0.0.1:5173,http://127.0.0.1:5174,http://localhost:5173,http://localhost:5174

# Optional audit service override
AUDIT_LOG_URL=http://localhost:3001/log
